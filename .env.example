# =========================
# LLM
# =========================
# Google Gemini API key used by triage nodes.
GEMINI_API_KEY=your_gemini_api_key_here
# LLM provider to use: gemini or openai.
LLM_PROVIDER=gemini
# OpenAI API key (required when LLM_PROVIDER=openai).
OPENAI_API_KEY=your_openai_api_key_here
# Model name for classification/summarization.
MODEL_NAME=gemini-2.5-flash

# =========================
# GitHub
# =========================
# Personal access token with issues:write scope.
GITHUB_TOKEN=your_github_token_here
# Target repository in owner/repo format.
GITHUB_REPO=your-org/your-repo

# =========================
# Slack
# =========================
# Default incoming webhook URL for incident channel notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Optional: route Slack notifications by assigned team (falls back to SLACK_WEBHOOK_URL).
# Example: {"payments-team":"https://hooks.slack.com/services/...","accounts-team":"https://hooks.slack.com/services/..."}
SLACK_TEAM_WEBHOOKS_JSON=

# =========================
# Email
# =========================
# SMTP server hostname (leave blank to enable mock mode).
SMTP_HOST=smtp.example.com
# SMTP port (587 for STARTTLS is common).
SMTP_PORT=587
# SMTP username/email sender.
SMTP_USER=incident-bot@example.com
# SMTP password or app-specific token.
SMTP_PASSWORD=your_smtp_password_here

# =========================
# Observability
# =========================
# Langfuse public key for tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# Langfuse secret key for tracing.
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# Langfuse API host URL.
LANGFUSE_HOST=https://cloud.langfuse.com

# =========================
# Vector DB
# =========================
# Local persistent path for Chroma client mode.
CHROMA_PATH=./chroma_data
# Network host for Chroma when accessed over HTTP.
CHROMA_HOST=vector-db
# Chroma HTTP port.
CHROMA_PORT=8000

# =========================
# App
# =========================
# Backend public URL used by frontend/integration callbacks.
BACKEND_URL=http://localhost:8000
# Local SQLite database path for ticket history.
SQLITE_DB_PATH=./data/sre_agent.db
# Path to local Reaction Commerce clone for ingestion (optional).
REACTION_COMMERCE_REPO_PATH=./data/reaction_commerce

# =========================
# Jira
# =========================
# Jira Cloud base URL.
JIRA_BASE_URL=https://your-site.atlassian.net
# Atlassian account email for API authentication.
JIRA_EMAIL=your-atlassian-email@example.com
# Jira API token for HTTP Basic auth.
JIRA_API_TOKEN=your-jira-api-token-here
# Jira project key where incidents are created.
JIRA_PROJECT_KEY=SRE
